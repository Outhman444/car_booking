# ==============================================================================
# إعدادات التطبيق الأساسية (المهمة جداً)
# ==============================================================================
# اسم التطبيق وبيئة التشغيل ومفتاح التشفير
APP_NAME="Real Rent Car"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
VITE_APP_NAME="${APP_NAME}"

# إعدادات اللغة الإقليمية الافتراضية
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ==============================================================================
# إعدادات قاعدة البيانات (ضرورية للتشغيل)
# ==============================================================================
# معلومات اتصال خادم قاعدة البيانات الخاصة بك
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=car_booking
DB_USERNAME=root
DB_PASSWORD=

# ==============================================================================
# إعدادات العملة والضرائب (المعاملات المالية)
# ==============================================================================
# رمز وكود العملة ونسبة الضريبة (مثال: 0.07 تعني 7 بالمائة)
APP_CURRENCY_SYMBOL=$
APP_CURRENCY_CODE=USD
TAX_RATE=0.07

# ==============================================================================
# بوابات الدفع (التكامل الخارجي للمدفوعات)
# ==============================================================================
# إعدادات باي بال PayPal
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_SANDBOX=true

# إعدادات سترايب Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ==============================================================================
# الجلسات، التخزين المؤقت، الطوابير (السرعة والأداء)
# ==============================================================================
# طريقة حفظ الجلسات وتخزين الكاش ومعالجة الخلفية
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# ==============================================================================
# إعدادات البريد الإلكتروني (إشعارات النظام)
# ==============================================================================
# إعدادات خادم الإيميلات لإرسال الفواتير والتنبيهات
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================================================
# السجلات ومتابعة الأخطاء (الصيانة وأمان النظام)
# ==============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==============================================================================
# إعدادات متقدمة وخوادم التخزين بذاكرة الوصول (اختياري)
# ==============================================================================
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

BROADCAST_CONNECTION=log

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
